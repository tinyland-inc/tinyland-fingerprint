{
  "name": "@tummycrypt/tinyland-fingerprint",
  "version": "0.2.2",
  "description": "Fingerprint intelligence services: enrichment, search, history, settings, validation, and caching",
  "type": "module",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:package": "publint",
    "prepublishOnly": "pnpm build && pnpm check:package"
  },
  "dependencies": {
    "@tummycrypt/tinyland-security": "workspace:^",
    "ua-parser-js": "^2.0.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@types/node": "^22.0.0",
    "@types/ua-parser-js": "^0.7.39",
    "fast-check": "^4.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "publint": "^0.3.18",
    "@tummycrypt/tinyland-security @tummycrypt/tinyland-otel": "^0.2.2"
  },
  "peerDependencies": {
    "@tummycrypt/tinyland-otel": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@tummycrypt/tinyland-otel": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyland-inc/tinyland-fingerprint.git"
  },
  "packageManager": "pnpm@10.13.1",
  "homepage": "https://github.com/tinyland-inc/tinyland-fingerprint",
  "bugs": {
    "url": "https://github.com/tinyland-inc/tinyland-fingerprint/issues"
  }
}